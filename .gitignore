./backend/dist/
./backend/build/
./backend/coverage/
./backend/.next/
./backend/.cache/

# Frontend build outputs
./frontend/dist/
./frontend/build/
./frontend/.next/
./frontend/.nuxt/
./frontend/.svelte-kit/
./frontend/.vuepress/dist/
./frontend/.cache/
./frontend/coverage/

