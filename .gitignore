# ============================================
# LOGS
# ============================================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# ENVIRONMENT VARIABLES - DO NOT COMMIT!
# ============================================
# Backend environment files
./backend/.env
./backend/.env.*
!./backend/.env.example
./edi_data:

# Frontend environment files
./frontend/.env
./frontend/.env.*
!./frontend/.env.example

# Root environment files (if any)
.env
.env.*
!.env.example

# ============================================
